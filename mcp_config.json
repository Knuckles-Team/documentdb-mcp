{
  "mcpServers": {
    "documentdb-mcp": {
      "command": "uv",
      "args": [
        "run",
        "documentdb-mcp"
      ],
      "env": {
        "MCP_TOOL_MODE": "condensed",
        "ANALYSISTOOL": "True",
        "COLLECTIONSTOOL": "True",
        "CRUDTOOL": "True",
        "MONGODB_HOST": "localhost",
        "MONGODB_PORT": "27017",
        "MONGODB_URI": "mongodb://localhost:27017/",
        "SYSTEMTOOL": "True",
        "USERSTOOL": "True"
      }
    }
  }
}
